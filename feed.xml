---
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0">
<channel>
  <title>{{ site.title | xml_escape }}</title>
  <link>{{ site.url }}/</link>
  <description>{{ site.title | xml_escape }}</description>
{% for post in site.posts limit:50 %}
  <item>
    <title>{{ post.title | xml_escape }}</title>
    <link>{{ site.url }}{{ post.url | replace: ' ', '%20' | xml_escape }}</link>
    <guid>{{ site.url }}{{ post.url | replace: ' ', '%20' | xml_escape }}</guid>
    <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
    <description>{{ post.excerpt | strip_html | normalize_whitespace | xml_escape }}</description>
  </item>
{% endfor %}
</channel>
</rss>
